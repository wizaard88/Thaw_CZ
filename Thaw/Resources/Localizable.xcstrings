    "Menu bar items are rehidden using a smart algorithm." : {
      "comment" : "A description of how the smart rehide strategy works.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikony řádku nabídek se skrývají na základě chytrého algoritmu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menüleisten-Einträge werden durch einen cleveren Algorithmus versteckt."
          }
        },
        "es" : {
