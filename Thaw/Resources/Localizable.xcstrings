          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli elementi della barra dei menu vengono nascosti di nuovo dopo un periodo di tempo prestabilito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
