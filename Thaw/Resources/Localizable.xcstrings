    "Layout reset. Items were moved to the Hidden section." : {
      "comment" : "A message displayed after successfully resetting the menu bar layout.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obnovení rozložení. Položky byly přesunuty do sekce „Skryté“."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Darstellung zurücksetzen. Einträge wurden in den verstecken Bereich verschoben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se restableció la disposición. Los elementos se movieron a la sección Ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disposition réinitialisée. Les éléments ont été déplacés vers la section masquée."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elrendezés visszaállítva. Az elemek a Rejtett szakaszba kerültek."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tata Letak diatur ulang. Item dipindahkan ke Bagian Tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Layout ripristinato. Gli elementi sono stati spostati nella sezione Nascosti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レイアウトをリセットしました。項目は非表示セクションに移動されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "레이아웃이 재설정되었습니다. 항목이 숨김 섹션으로 이동되었습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lay-out opnieuw ingesteld. Items zijn verplaatst naar de verborgen sectie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przywrócono domyślny układ. Obiekty przeniesiono do ukrytej sekcji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Layout redefinido. Os itens foram movidos para a seção Ocultos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Расположение сброшено. Элементы перемещены в секцию скрытых."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "รีเซ็ตการจัดวางใหม่ รายการจะถูกย้ายไปยัง “หมวดหมู่ที่ซ่อนอยู่”"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Düzen sıfırlandı. Öğeler Gizli bölüme taşındı."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розмітку скинуто. Об'єкти переміщено до розділу «Приховані»."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đặt lại bố cục. Các mục đã được chuyển đến phần Ẩn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "布局重置。 项目已移至已隐藏区域。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "佈局已重置。項目已移至隱藏區域。"
          }
        }
      }
    },
