        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È anche possibile organizzare gli elementi tenendo premuto ⌘ Comando e trascinandoli nella barra dei menu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
