    "Apply different settings based on the current system appearance." : {
      "comment" : "Label for a toggle that allows the user to choose whether to use different appearance settings based on the current system appearance.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Použít různé nastavení v závislosti na aktuálním vzhledu systému."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterschiedliche Einstellungen basierend auf der aktuellen Systemdarstellung anwenden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplicar ajustes diferentes según la apariencia actual del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applique des réglages différents à la barre des menus en fonction de l'apparence actuelle du système (clair ou sombre). "
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Különböző beállítások alkalmazása az aktuális rendszermegjelenés alapján."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terapkan pengaturan yang berbeda berdasarkan tampilan sistem."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applica impostazioni diverse in base all'aspetto attuale del sistema."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のシステム外観に基づいて異なる設定を適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 시스템 모양에 따라 다른 설정을 적용합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pas verschillende instellingen toe op basis van het huidige uiterlijk van het systeem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zastosuj różne ustawienia w zależności od aktualnego wyglądu systemu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique diferentes configurações com base na aparência atual do sistema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применять разные настройки в зависимости от текущего оформления системы."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ใช้การตั้งค่าลักษณะที่แตกต่างกันตามลักษณะของระบบในปัจจุบัน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mevcut sistem görünümüne göre farklı ayarlar uygula."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застосовувати різні налаштування залежно від поточного оформлення системи."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Áp dụng các cài đặt khác nhau dựa trên giao diện hệ thống hiện tại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据目前的系统外观以应用不同的设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根據目前的系統外觀套用不同設定。"
          }
        }
      }
    },
    "Apply the current spacing" : {
