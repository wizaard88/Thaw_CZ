    "Can toggle settings: auto-rehide, show on click/hover/scroll, Thaw Bar, and other boolean options." : {
      "comment" : "Description of the permissions of a whitelisted app.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Může přepínat nastavení: automatické skrytí, zobrazení při kliknutí/najetí myší/rolování, lišta Thaw a další přepínače."
          }
        },
        "de" : {
          "stringUnit" : {
