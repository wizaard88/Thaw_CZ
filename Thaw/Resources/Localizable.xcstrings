    "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again." : {
      "comment" : "A step in the process of whitelisting an app.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud udělíte oprávnění, aplikace bude trvale zařazena na seznam povolených a bude moci kdykoli měnit nastavení, aniž by vás o to znovu žádala."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn bestätigt, wird die Anwendung dauerhaft auf der Whitelist stehen und kann Einstellungen jederzeit ohne erneute Rückfrage verändern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si aprueba, la aplicación está permanentemente en whitelist y puede modificar los ajustes en cualquier momento sin preguntar de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika diizinkan, aplikasi ini akan masuk daftar izin permanen dan dapat mengubah pengaturan kapanpun tanpa izin lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "承認すると、アプリは永久にホワイトリストに登録され、再度尋ねることなくいつでも設定を変更できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you approve, the app is permanently whitelisted and can modify settings anytime without asking again."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli wyrazisz zgodę, aplikacja zostanie trwale dodana do białej listy i będzie mogła modyfikować ustawienia w dowolnym momencie, bez ponownego pytania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "new",
