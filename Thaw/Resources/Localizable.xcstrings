    "Menu bar items are rehidden after a fixed amount of time." : {
      "comment" : "A description of how the rehide strategy works when set to \"timed\".",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikony řádku nabídek se skryjí po uplynutí dané doby."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menüleisten-Eintäge werden nach einer festgelegten Zeitspanne versteckt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos de la barra de menús se vuelven a ocultar después de un tiempo fijo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments de la barre des menus sont masqués automatiquement après un délai fixe."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
