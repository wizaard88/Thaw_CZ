    "Note: You may need to log out and back in for this setting to apply properly." : {
      "comment" : "Note displayed in the annotation for the `GeneralSettingsPane` view, explaining that the spacing setting may require a logout and login to take effect.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poznámka: Aby se toto nastavení správně uplatnilo, může být nutné se odhlásit a znovu přihlásit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinweis: Um diese Einstellung anzuwenden, ist es möglicherweise notwendig sich an- und wieder anzumelden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nota: es posible que tengas que cerrar sesión y volver a iniciarla para que este ajuste se aplique correctamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remarque : vous devrez peut-être vous déconnecter, puis vous reconnecter, pour que ce réglage soit appliqué correctement."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Megjegyzés: Előfordulhat, hogy ki kell jelentkeznie és újra be kell jelentkeznie a beállítás megfelelő alkalmazásához."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catatan: Anda mungkin perlu keluar lalu masuk kembali agar pengaturan ini berlaku dengan benar."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nota: potrebbe essere necessario disconnettersi e riconnettersi affinché questa impostazione venga applicata correttamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注意: この設定を正しく適用するには、一度ログアウトして再度ログインする必要がある場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "참고: 이 설정을 올바르게 적용하려면 로그아웃 후 다시 로그인해야 할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opmerking: Mogelijk moet u zich afmelden en opnieuw aanmelden om deze instelling correct toe te passen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Informacja: To ustawienie zacznie działać po ponownym zalogowaniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Observação: pode ser necessário encerrar e iniciar sessão novamente para que esta configuração seja aplicada corretamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примечание: для корректного применения этого параметра может потребоваться выйти из системы и войти снова."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หมายเหตุ: คุณอาจต้องออกจากระบบแล้วเข้าสู่ระบบใหม่อีกครั้งเพื่อให้การตั้งค่านี้มีผลอย่างถูกต้อง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Not: Bu ayarın düzgün uygulanması için oturumu kapatıp tekrar açmanız gerekebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примітка: для належного застосування цього налаштування може знадобитися вийти з облікового запису й увійти знову."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lưu ý: Bạn có thể cần phải đăng xuất và đăng nhập lại để cài đặt này được áp dụng đúng cách."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注意：您可能需要注销并重新登录才能使此设置生效。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注意：您可能需要登出並重新登入才能正確套用此設定。"
          }
        }
      }
    },
