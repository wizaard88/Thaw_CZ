    "Not available because the %@ Bar is enabled for this display." : {
      "comment" : "A message explaining that the \"Always show hidden items\" toggle is not available when the \"Use \\(Constants.displayName) Bar\" toggle is enabled.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Není k dispozici, protože pro tuto obrazovku je aktivována lišta %@."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nicht verfügbar, weil die %@-Leiste für diesen Bildschirm aktiviert ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No disponible porque la barra de %@ está activada en esta pantalla."
          }
        },
