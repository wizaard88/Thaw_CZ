        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die %1$@-Leiste benötigt Berechtigungen für die Aufnahme von Bildschirm & Systemaudio."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra de %@ requiere permisos de grabación de pantalla."
