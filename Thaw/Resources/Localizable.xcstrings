        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non disponibile perché la barra %@ è abilitata per questa visualizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このディスプレイで %@ バーが有効なため、使用できません。"
